{"ast":null,"code":"export default {\n  props: [\"imgUrl\", \"location\", \"title\", \"description\"]\n};","map":{"version":3,"names":["props"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\EventCard.vue"],"sourcesContent":["<template>\r\n  <div class=\"card\">\r\n    <div class=\"img-wrapper\">\r\n        <!-- <img src=\"@/assets/images/hero.jpg\" alt=\"Event image\"> -->\r\n        <img :src=\"imgUrl\" alt=\"Event image\">\r\n    </div>\r\n    <div class=\"card-content\">\r\n        <div class=\"tag\"><p>{{ location }}</p></div>\r\n        <h5>{{ title }}</h5>\r\n        <ul>\r\n            <li v-for=\"(d,i) in description\" :key=\"i\">{{ d }}</li>\r\n        </ul>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    props: [\"imgUrl\",\"location\", \"title\", \"description\"],\r\n\r\n    \r\n}\r\n</script>\r\n\r\n<style scoped lang=\"scss\">\r\n.card {\r\n    width:482px;\r\n    height:100%;\r\n    background-color: $dark;\r\n    border-radius: 22px;\r\n    display: flex;\r\n    flex-direction: column;\r\n    \r\n    \r\n    // gap:32px;\r\n    \r\n    .img-wrapper {\r\n        width: 100%;\r\n        height: 256px;\r\n        overflow: hidden;\r\n        border-radius: 22px 22px 0 0;\r\n        position: relative;\r\n        // transform-origin: center;\r\n        // transition: transform 0.3s ease-out; /* Smooth transitions */\r\n        // background-color:grey;\r\n        \r\n        .img-wrapper img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n            transition: transform 0.3s ease-out; /* Smooth transitions */\r\n        }\r\n    }\r\n    \r\n    .card-content {\r\n        color:$white;\r\n        padding:32px;\r\n        display: flex;\r\n        flex-direction: column;\r\n        gap:32px;\r\n        .tag {\r\n            color: $yellow;\r\n            font-size:10px;\r\n            width:fit-content;\r\n            padding:16px 32px;\r\n            border-radius: 23px;\r\n            border: solid 1px $yellow;\r\n            p {font-size:13px; }\r\n        }\r\n        \r\n        h5{padding:8px 0;}\r\n\r\n        p {\r\n            font-size:16px;\r\n        }\r\n        ul {list-style: none;}\r\n    }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n    .card {\r\n        width:45vw;\r\n    }\r\n}\r\n@media (max-width: 800px) {\r\n    .card {\r\n        width:65vw;\r\n    }\r\n}\r\n\r\n@media (max-width: 500px) {\r\n    .card {\r\n        width:55vw;\r\n        height:80%;\r\n\r\n        .card-content {\r\n            padding:32px;\r\n            display: flex;\r\n            flex-direction: column;\r\n            gap:32px;\r\n        .tag {\r\n            padding:4px 7px;\r\n            p {font-size:6px; }\r\n        }\r\n        \r\n        h5{\r\n            font-size:18px;\r\n            padding:8px 0;}\r\n\r\n        p {\r\n            font-size:8px;\r\n        }\r\n        \r\n    }\r\n    }\r\n}\r\n\r\n</style>"],"mappings":"AAiBA,eAAe;EACXA,KAAK,EAAE,CAAC,QAAQ,EAAC,UAAU,EAAE,OAAO,EAAE,aAAa;AAGvD","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}