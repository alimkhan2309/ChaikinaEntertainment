{"ast":null,"code":"import { Swiper, SwiperSlide } from \"swiper/vue\";\nimport \"swiper/swiper-bundle.css\";\nimport eventData from \"@/assets/data/events.json\";\nimport EventCard from \"../EventCard.vue\";\nexport default {\n  components: {\n    Swiper,\n    SwiperSlide,\n    EventCard\n  },\n  data() {\n    return {\n      events: eventData.events,\n      isMobile: window.innerWidth <= 800 // Set initial layout\n    };\n  },\n  mounted() {\n    window.addEventListener(\"resize\", this.checkScreenSize);\n  },\n  beforeDestroy() {\n    window.removeEventListener(\"resize\", this.checkScreenSize);\n  },\n  methods: {\n    checkScreenSize() {\n      this.isMobile = window.innerWidth <= 800; // Update layout dynamically\n    },\n    getImageUrl(imagePath) {\n      return require(`@/assets/images/${imagePath}`);\n    }\n  }\n};","map":{"version":3,"names":["Swiper","SwiperSlide","eventData","EventCard","components","data","events","isMobile","window","innerWidth","mounted","addEventListener","checkScreenSize","beforeDestroy","removeEventListener","methods","getImageUrl","imagePath","require"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\HomeSections\\EventSection.vue"],"sourcesContent":["<template>\r\n  <section class=\"events\">\r\n    <h1>Our Spectacular Show</h1>\r\n\r\n    <!-- FLEX BOX -->\r\n     <div \r\n     v-if=\"!isMobile\"\r\n     class=\"event-cards flexbox-layout\">\r\n        <router-link\r\n            v-for=\"event in events\"\r\n            :key=\"event.id\"\r\n            :to=\"{\r\n            name: 'EventView',\r\n            params: { id: event.id },\r\n            query: { eventData: JSON.stringify(event) },\r\n            }\"\r\n            class=\"card-link\"\r\n        >\r\n            <EventCard\r\n                :imgUrl=\"getImageUrl(event.image)\"\r\n                :location=\"event.location\"\r\n                :title=\"event.name\"\r\n                :description=\"event.brief\"\r\n            />\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Slider -->\r\n    <swiper\r\n        v-else\r\n        :slidesPerView=\"3\"\r\n        :space-between:=\"16\"\r\n        class=\"swiper-layout\">\r\n        \r\n        <swiper-slide\r\n        v-for=\"event in events\"\r\n        :key=\"event.id\">\r\n            <router-link\r\n            :to=\"{\r\n            name: 'EventView',\r\n            params: { id: event.id },\r\n            query: { eventData: JSON.stringify(event) },\r\n            }\"\r\n            class=\"card-link\"\r\n        >\r\n            <EventCard\r\n                :imgUrl=\"getImageUrl(event.image)\"\r\n                :location=\"event.location\"\r\n                :title=\"event.name\"\r\n                :description=\"event.brief\"\r\n            />\r\n        </router-link>\r\n        </swiper-slide>\r\n\r\n    </swiper>\r\n\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nimport { Swiper, SwiperSlide } from \"swiper/vue\";\r\nimport \"swiper/swiper-bundle.css\";\r\nimport eventData from \"@/assets/data/events.json\";\r\nimport EventCard from \"../EventCard.vue\";\r\n\r\nexport default {\r\n  components: { Swiper, SwiperSlide, EventCard },\r\n  data() {\r\n    return {\r\n      events: eventData.events,\r\n      isMobile: window.innerWidth <= 800, // Set initial layout\r\n    };\r\n  },\r\n  mounted() {\r\n    window.addEventListener(\"resize\", this.checkScreenSize);\r\n  },\r\n  beforeDestroy() {\r\n    window.removeEventListener(\"resize\", this.checkScreenSize);\r\n  },\r\n  methods: {\r\n    checkScreenSize() {\r\n      this.isMobile = window.innerWidth <= 800; // Update layout dynamically\r\n    },\r\n    getImageUrl(imagePath) {\r\n      return require(`@/assets/images/${imagePath}`);\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n\r\n<style scoped lang=\"scss\">\r\n.events {\r\n  width: 100%;\r\n  height: fit-content;\r\n  background-color: $black;\r\n  color: white;\r\n\r\n  h1 {\r\n    padding: $vertical-padding 0;\r\n    text-align: center;\r\n  }\r\n\r\n  .event-cards {\r\n    width: 100%;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: stretch;\r\n    gap: 64px;\r\n    margin-top: 128px;\r\n    flex-wrap: wrap;\r\n    overflow-x: auto;\r\n    box-sizing: border-box;\r\n    -webkit-overflow-scrolling: touch; // Smooth scrolling on iOS\r\n    scroll-behavior: smooth;\r\n\r\n    &::-webkit-scrollbar {\r\n      height: 8px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-thumb {\r\n      background: $yellow;\r\n      border-radius: 4px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-track {\r\n      background: $dark;\r\n    }\r\n\r\n    .card-link {\r\n      text-decoration: none;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .events {\r\n    .event-cards {\r\n        display: grid;\r\n        grid-auto-flow: column;\r\n        grid-auto-columns: 90%;\r\n        gap: 16px;\r\n        overflow-x: auto;\r\n        overflow-y: hidden;\r\n        -webkit-overflow-scrolling: touch;\r\n        scroll-behavior: smooth;\r\n        padding: 16px;\r\n\r\n        &::-webkit-scrollbar {\r\n            height: 8px;\r\n        }\r\n\r\n        &::-webkit-scrollbar-thumb {\r\n            background: $yellow;\r\n            border-radius: 4px;\r\n        }\r\n\r\n        &::-webkit-scrollbar-track {\r\n            background: $dark;\r\n        }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 800px) {\r\n  .events {\r\n    .event-cards {\r\n      margin: 0;\r\n      grid-auto-columns: 62%; // Adjusted for mobile view\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 500px) {\r\n  .events {\r\n    h1 {\r\n      font-size: $h1-mobile;\r\n      padding: 32px 0 64px 24px;\r\n      width: fit-content;\r\n      text-align: start;\r\n    }\r\n    .event-cards {\r\n      grid-auto-columns: 85%;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA4DA,SAASA,MAAM,EAAEC,WAAU,QAAS,YAAY;AAChD,OAAO,0BAA0B;AACjC,OAAOC,SAAQ,MAAO,2BAA2B;AACjD,OAAOC,SAAQ,MAAO,kBAAkB;AAExC,eAAe;EACbC,UA