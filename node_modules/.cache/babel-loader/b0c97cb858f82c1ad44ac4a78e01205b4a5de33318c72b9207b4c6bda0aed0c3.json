{"ast":null,"code":"export default {\n  data() {\n    return {\n      isMenuOpen: false\n    };\n  },\n  computed: {\n    isMobile() {\n      return window.innerWidth <= 500;\n    }\n  },\n  methods: {\n    toggleMenu() {\n      this.isMenuOpen = !this.isMenuOpen;\n    }\n  },\n  created() {\n    window.addEventListener(\"resize\", () => {\n      if (!this.isMobile && this.isMenuOpen) this.isMenuOpen = false;\n    });\n  }\n};","map":{"version":3,"names":["data","isMenuOpen","computed","isMobile","window","innerWidth","methods","toggleMenu","created","addEventListener"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\Navbar.vue"],"sourcesContent":["<template>\r\n  <nav class=\"navbar\">\r\n    <div class=\"logo\">CHAIKINA ENTERTAINMENT</div>\r\n    <div class=\"links\" v-if=\"!isMobile\">\r\n      <router-link to=\"/\">Home</router-link>\r\n      <router-link to=\"/about\">About</router-link>\r\n      <router-link to=\"/services\">Services</router-link>\r\n      <router-link to=\"/contact\">Contact</router-link>\r\n    </div>\r\n    <button class=\"action-btn\" v-if=\"!isMobile\">Action</button>\r\n    <button class=\"burger-btn\" v-if=\"isMobile\" @click=\"toggleMenu\">&#9776;</button>\r\n    <div class=\"side-menu\" :class=\"{ open: isMenuOpen }\">\r\n      <div class=\"menu-links\">\r\n        <router-link to=\"/\" @click=\"toggleMenu\">Home</router-link>\r\n        <router-link to=\"/about\" @click=\"toggleMenu\">About</router-link>\r\n        <router-link to=\"/services\" @click=\"toggleMenu\">Services</router-link>\r\n        <router-link to=\"/contact\" @click=\"toggleMenu\">Contact</router-link>\r\n      </div>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      isMenuOpen: false,\r\n    };\r\n  },\r\n  computed: {\r\n    isMobile() {\r\n      return window.innerWidth <= 500;\r\n    },\r\n  },\r\n  methods: {\r\n    toggleMenu() {\r\n      this.isMenuOpen = !this.isMenuOpen;\r\n    },\r\n  },\r\n  created() {\r\n    window.addEventListener(\"resize\", () => {\r\n      if (!this.isMobile && this.isMenuOpen) this.isMenuOpen = false;\r\n    });\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\">\r\n$black: #000;\r\n$white: #fff;\r\n\r\n.navbar {\r\n  width: 100%;\r\n  position:fixed;\r\n  background-color: $black;\r\n  color: $white;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: 0.5rem 1rem;\r\n  font-family: 'Libre Baskerville', serif;\r\n\r\n  .logo {\r\n    font-size: 1.5rem;\r\n  }\r\n\r\n  .links {\r\n    display: flex;\r\n    gap: 1rem;\r\n\r\n    a {\r\n      color: $white;\r\n      text-decoration: none;\r\n    }\r\n  }\r\n\r\n  .action-btn {\r\n    background-color: $white;\r\n    color: $black;\r\n    border: none;\r\n    padding: 0.5rem 1rem;\r\n    cursor: pointer;\r\n    font-size: 1rem;\r\n  }\r\n\r\n  .burger-btn {\r\n    display: none;\r\n    background: none;\r\n    color: $white;\r\n    border: none;\r\n    font-size: 1.5rem;\r\n    cursor: pointer;\r\n  }\r\n\r\n  .side-menu {\r\n    position: fixed;\r\n    top: 0;\r\n    right: -300px;\r\n    width: 300px;\r\n    height: 100%;\r\n    background-color: $black;\r\n    color: $white;\r\n    transition: right 0.3s ease-in-out;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n    padding: 1rem;\r\n\r\n    &.open {\r\n      right: 0;\r\n    }\r\n\r\n    .menu-links {\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 1rem;\r\n\r\n      a {\r\n        color: $white;\r\n        text-decoration: none;\r\n        font-size: 1.2rem;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .navbar {\r\n    .logo {\r\n      font-size: 1.2rem;\r\n    }\r\n    .links {\r\n      gap: 0.8rem;\r\n    }\r\n    .action-btn {\r\n      font-size: 0.9rem;\r\n      padding: 0.4rem 0.8rem;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 800px) {\r\n  .navbar {\r\n    .logo {\r\n      font-size: 1rem;\r\n    }\r\n    .links {\r\n      display: none;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 500px) {\r\n  .navbar {\r\n    .burger-btn {\r\n      display: block;\r\n    }\r\n    .action-btn {\r\n      display: none;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAuBA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE;IACd,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,QAAQA,CAAA,EAAG;MACT,OAAOC,MAAM,CAACC,UAAS,IAAK,GAAG;IACjC;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAAA,EAAG;MACX,IAAI,CAACN,UAAS,GAAI,CAAC,IAAI,CAACA,UAAU;IACpC;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACRJ,MAAM,CAACK,gBAAgB,CAAC,QAAQ,EAAE,MAAM;MACtC,IAAI,CAAC,IAAI,CAACN,QAAO,IAAK,IAAI,CAACF,UAAU,EAAE,IAAI,CAACA,UAAS,GAAI,KAAK;IAChE,CAAC,CAAC;EACJ;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}