{"ast":null,"code":"import eventData from \"@/assets/data/events.json\";\nimport EventCard from \"../EventCard.vue\";\nexport default {\n  components: {\n    EventCard\n  },\n  data() {\n    return {\n      events: eventData.events\n    };\n  },\n  mounted() {\n    this.$nextTick(() => {\n      const container = this.$refs.eventCards;\n      if (container) {\n        container.scrollLeft = 0; // Ensure slider starts at the beginning\n      }\n    });\n  },\n  methods: {\n    getImageUrl(imagePath) {\n      return require(`@/assets/images/${imagePath}`);\n    }\n  }\n};","map":{"version":3,"names":["eventData","EventCard","components","data","events","mounted","$nextTick","container","$refs","eventCards","scrollLeft","methods","getImageUrl","imagePath","require"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\HomeSections\\EventSection.vue"],"sourcesContent":["<template>\r\n  <section class=\"events\">\r\n    <h1>Our Spectacular Show</h1>\r\n    <div ref=\"eventCards\" class=\"event-cards\">\r\n      <router-link\r\n        v-for=\"event in events\"\r\n        :key=\"event.id\"\r\n        :to=\"{\r\n          name: 'EventView',\r\n          params: { id: event.id },\r\n          query: { eventData: JSON.stringify(event) },\r\n        }\"\r\n        class=\"card-link\"\r\n      >\r\n        <EventCard\r\n          :imgUrl=\"getImageUrl(event.image)\"\r\n          :location=\"event.location\"\r\n          :title=\"event.name\"\r\n          :description=\"event.brief\"\r\n        />\r\n      </router-link>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nimport eventData from \"@/assets/data/events.json\";\r\nimport EventCard from \"../EventCard.vue\";\r\n\r\nexport default {\r\n  components: { EventCard },\r\n  data() {\r\n    return {\r\n      events: eventData.events,\r\n    };\r\n  },\r\n  mounted() {\r\n    this.$nextTick(() => {\r\n      const container = this.$refs.eventCards;\r\n      if (container) {\r\n        container.scrollLeft = 0; // Ensure slider starts at the beginning\r\n      }\r\n    });\r\n  },\r\n  methods: {\r\n    getImageUrl(imagePath) {\r\n      return require(`@/assets/images/${imagePath}`);\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped lang=\"scss\">\r\n.events {\r\n  width: 100%;\r\n  height: fit-content;\r\n  background-color: $black;\r\n  color: white;\r\n\r\n  h1 {\r\n    padding: $vertical-padding 0;\r\n    text-align: center;\r\n  }\r\n\r\n  .event-cards {\r\n    width: 100%;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: stretch;\r\n    gap: 64px;\r\n    margin-top: 128px;\r\n    flex-wrap: wrap;\r\n    overflow-x: auto;\r\n    box-sizing: border-box;\r\n    -webkit-overflow-scrolling: touch; // Smooth scrolling on iOS\r\n    scroll-behavior: smooth;\r\n\r\n    &::-webkit-scrollbar {\r\n      height: 8px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-thumb {\r\n      background: $yellow;\r\n      border-radius: 4px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-track {\r\n      background: $dark;\r\n    }\r\n\r\n    .card-link {\r\n      text-decoration: none;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .events {\r\n    .event-cards {\r\n      display: grid;\r\n      grid-auto-flow: column;\r\n      grid-auto-columns: 45%;\r\n      overflow-x: auto;\r\n      scroll-snap-type: x mandatory; // For better UX on mobile\r\n      gap: 16px;\r\n\r\n      &::-webkit-scrollbar {\r\n        height: 8px;\r\n      }\r\n\r\n      &::-webkit-scrollbar-thumb {\r\n        background: $yellow;\r\n        border-radius: 4px;\r\n      }\r\n\r\n      &::-webkit-scrollbar-track {\r\n        background: $dark;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 800px) {\r\n  .events {\r\n    .event-cards {\r\n      margin: 0;\r\n      grid-auto-columns: 62%; // Adjusted for mobile view\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 500px) {\r\n  .events {\r\n    h1 {\r\n      font-size: $h1-mobile;\r\n      padding: 32px 0 64px 24px;\r\n      width: fit-content;\r\n      text-align: start;\r\n    }\r\n    .event-cards {\r\n      grid-auto-columns: auto;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA0BA,OAAOA,SAAQ,MAAO,2BAA2B;AACjD,OAAOC,SAAQ,MAAO,kBAAkB;AAExC,eAAe;EACbC,UAAU,EAAE;IAAED;EAAU,CAAC;EACzBE,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAEJ,SAAS,CAACI;IACpB,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,SAAS,CAAC,MAAM;MACnB,MAAMC,SAAQ,GAAI,IAAI,CAACC,KAAK,CAACC,UAAU;MACvC,IAAIF,SAAS,EAAE;QACbA,SAAS,CAACG,UAAS,GAAI,CAAC,EAAE;MAC5B;IACF,CAAC,CAAC;EACJ,CAAC;EACDC,OAAO,EAAE;IACPC,WAAWA,CAACC,SAAS,EAAE;MACrB,OAAOC,OAAO,CAAC,mBAAmBD,SAAS,EAAE,CAAC;IAChD;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}