{"ast":null,"code":"import { Swiper, SwiperSlide } from \"swiper/vue\";\nimport \"swiper/swiper-bundle.css\";\nimport eventData from \"@/assets/data/events.json\";\nimport EventCard from \"../EventCard.vue\";\nexport default {\n  components: {\n    Swiper,\n    SwiperSlide,\n    EventCard\n  },\n  props: [\"isMobile\"],\n  data() {\n    return {\n      events: eventData.events\n    };\n  }\n};","map":{"version":3,"names":["Swiper","SwiperSlide","eventData","EventCard","components","props","data","events"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\HomeSections\\EventSection.vue"],"sourcesContent":["<template>\r\n  <section class=\"events\">\r\n    <h1>Our Spectacular Show</h1>\r\n\r\n    <!-- FLEX BOX -->\r\n     <div  v-show=\"!isMobile\"\r\n     class=\"event-cards flexbox-layout\">\r\n        <router-link\r\n            v-for=\"event in events\"\r\n            :key=\"event.id\"\r\n            :to=\"{\r\n            name: 'EventView',\r\n            params: { id: event.id },\r\n            query: { eventData: JSON.stringify(event) },\r\n            }\"\r\n            class=\"card-link\"\r\n        >\r\n            <EventCard\r\n                :imgUrl=\"getImageUrl(event.image)\"\r\n                :location=\"event.location\"\r\n                :title=\"event.name\"\r\n                :description=\"event.brief\"\r\n            />\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Slider -->\r\n    <swiper\r\n        v-show=\"isMobile\"\r\n        :slides-per-view=\"3\"\r\n        :space-between=\"16\"\r\n        class=\"swiper-layout\">\r\n        \r\n        <swiper-slide\r\n        v-for=\"event in events\"\r\n        class=\"swiper-slide\"\r\n        :key=\"event.id\">\r\n            <router-link\r\n            :to=\"{\r\n            name: 'EventView',\r\n            params: { id: event.id },\r\n            query: { eventData: JSON.stringify(event) },\r\n            }\"\r\n            class=\"card-link\"\r\n        >\r\n            <EventCard\r\n                :imgUrl=\"getImageUrl(event.image)\"\r\n                :location=\"event.location\"\r\n                :title=\"event.name\"\r\n                :description=\"event.brief\"\r\n            />\r\n        </router-link>\r\n        </swiper-slide>\r\n\r\n    </swiper>\r\n\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nimport { Swiper, SwiperSlide } from \"swiper/vue\";\r\nimport \"swiper/swiper-bundle.css\";\r\nimport eventData from \"@/assets/data/events.json\";\r\nimport EventCard from \"../EventCard.vue\";\r\n\r\nexport default {\r\n  components: { Swiper, SwiperSlide, EventCard },\r\n  props: [\"isMobile\"],\r\n  data() {\r\n    return {\r\n      events: eventData.events\r\n    };\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped lang=\"scss\">\r\n\r\n@import \"~swiper/swiper-bundle\";\r\n\r\n.events {\r\n  width: 100%;\r\n  height: fit-content;\r\n  background-color: $black;\r\n  color: white;\r\n  padding: 16px;\r\n\r\n  h1 {\r\n    padding-bottom: 24px;\r\n    text-align: center;\r\n  }\r\n\r\n  /* Flexbox Layout for large screens */\r\n  .flexbox-layout {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 16px;\r\n    justify-content: center;\r\n\r\n    .event-card {\r\n      flex: 1 0 30%; /* Adjust card size as needed */\r\n      max-width: 400px;\r\n    }\r\n  }\r\n\r\n  /* Swiper Layout for smaller screens */\r\n  .swiper-layout {\r\n    width: 100%;\r\n    background-color: aliceblue;\r\n    .swiper-slide {\r\n      display: flex;\r\n      justify-content: center;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA4DA,SAASA,MAAM,EAAEC,WAAU,QAAS,YAAY;AAChD,OAAO,0BAA0B;AACjC,OAAOC,SAAQ,MAAO,2BAA2B;AACjD,OAAOC,SAAQ,MAAO,kBAAkB;AAExC,eAAe;EACbC,UAAU,EAAE;IAAEJ,MAAM;IAAEC,WAAW;IAAEE;EAAU,CAAC;EAC9CE,KAAK,EAAE,CAAC,UAAU,CAAC;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAEL,SAAS,CAACK;IACpB,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}