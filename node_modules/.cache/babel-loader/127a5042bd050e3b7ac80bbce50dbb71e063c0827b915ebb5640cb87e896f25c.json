wrap: wrap;\r\n    overflow-x: auto;\r\n    box-sizing: border-box;\r\n    -webkit-overflow-scrolling: touch; // Smooth scrolling on iOS\r\n    scroll-behavior: smooth;\r\n\r\n    &::-webkit-scrollbar {\r\n      height: 8px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-thumb {\r\n      background: $yellow;\r\n      border-radius: 4px;\r\n    }\r\n\r\n    &::-webkit-scrollbar-track {\r\n      background: $dark;\r\n    }\r\n\r\n    .card-link {\r\n      text-decoration: none;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .events {\r\n    .event-cards {\r\n        display: grid;\r\n        grid-auto-flow: column;\r\n        grid-auto-columns: 90%;\r\n        gap: 16px;\r\n        overflow-x: auto;\r\n        overflow-y: hidden;\r\n        -webkit-overflow-scrolling: touch;\r\n        scroll-behavior: smooth;\r\n        padding: 16px;\r\n\r\n        &::-webkit-scrollbar {\r\n            height: 8px;\r\n        }\r\n\r\n        &::-webkit-scrollbar-thumb {\r\n            background: $yellow;\r\n            border-radius: 4px;\r\n        }\r\n\r\n        &::-webkit-scrollbar-track {\r\n            background: $dark;\r\n        }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 800px) {\r\n  .events {\r\n    .event-cards {\r\n      margin: 0;\r\n      grid-auto-columns: 62%; // Adjusted for mobile view\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 500px) {\r\n  .events {\r\n    h1 {\r\n      font-size: $h1-mobile;\r\n      padding: 32px 0 64px 24px;\r\n      width: fit-content;\r\n      text-align: start;\r\n    }\r\n    .event-cards {\r\n      grid-auto-columns: auto;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;EACWA,KAAK,EAAC;AAAQ;;EAEhBC,GAAG,EAAC,YAAY;EAACD,KAAK,EAAC;;;;;uBAF9BE,mBAAA,CAqBU,WArBVC,UAqBU,G,0BApBRC,mBAAA,CAA6B,YAAzB,sBAAoB,sBACxBA,mBAAA,CAkBM,OAlBNC,UAkBM,I,kBAjBJH,mBAAA,CAgBcI,SAAA,QApBpBC,WAAA,CAKwBC,KAAA,CAAAC,MAAM,EAAfC,KAAK;yBADdC,YAAA,CAgBcC,sBAAA;MAdXC,GAAG,EAAEH,KAAK,CAACI,EAAE;MACbC,EAAE;;;cAA2DL,KAAK,CAACI;QAAE;;qBAAmCE,IAAI