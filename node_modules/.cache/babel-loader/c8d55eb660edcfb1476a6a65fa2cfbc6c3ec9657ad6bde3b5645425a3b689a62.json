{"ast":null,"code":"import { Swiper, SwiperSlide } from \"swiper/vue\";\nimport \"swiper/swiper-bundle.css\";\nimport eventData from \"@/assets/data/events.json\";\nimport EventCard from \"../EventCard.vue\";\nexport default {\n  components: {\n    Swiper,\n    SwiperSlide,\n    EventCard\n  },\n  data() {\n    return {\n      events: eventData.events,\n      screenWidth: window.innerWidth,\n      // Track screen width\n      isMobile: window.innerWidth < 800 // Determine if the screen is mobile (less than 800px)\n    };\n  },\n  computed: {\n    // Dynamically compute slidesPerView based on screen width\n    slidesPerView() {\n      if (this.screenWidth < 500) {\n        return 1; // 1 card for screens less than 500px\n      } else if (this.screenWidth < 800) {\n        return 2; // 2 cards for screens between 500px and 800px\n      } else {\n        return 3; // 3 cards for screens larger than 800px\n      }\n    }\n  },\n  methods: {\n    getImageUrl(imagePath) {\n      return require(\"@/assets/images/\" + imagePath);\n    },\n    // Update screenWidth and isMobile when the window is resized\n    updateScreenWidth() {\n      this.screenWidth = window.innerWidth;\n      this.isMobile = this.screenWidth < 800;\n    }\n  },\n  mounted() {\n    // Add resize event listener when component is mounted\n    window.addEventListener(\"resize\", this.updateScreenWidth);\n  },\n  beforeDestroy() {\n    // Clean up the event listener when the component is destroyed\n    window.removeEventListener(\"resize\", this.updateScreenWidth);\n  }\n};","map":{"version":3,"names":["Swiper","SwiperSlide","eventData","EventCard","components","data","events","screenWidth","window","innerWidth","isMobile","computed","slidesPerView","methods","getImageUrl","imagePath","require","updateScreenWidth","mounted","addEventListener","beforeDestroy","removeEventListener"],"sources":["C:\\Users\\Alimkhan\\Desktop\\websites\\chaikinaentertainment\\src\\components\\HomeSections\\EventSection.vue"],"sourcesContent":["<template>\r\n  <section class=\"events\">\r\n    <h1>Our Spectacular Show</h1>\r\n\r\n    <!-- FLEX BOX for desktop -->\r\n    <div v-show=\"!isMobile\" class=\"event-cards flexbox-layout\">\r\n      <router-link\r\n        v-for=\"event in events\"\r\n        :key=\"event.id\"\r\n        :to=\"{\r\n          name: 'EventView',\r\n          params: { id: event.id },\r\n          query: { eventData: JSON.stringify(event) },\r\n        }\"\r\n        class=\"card-link\"\r\n      >\r\n        <EventCard\r\n          :imgUrl=\"getImageUrl(event.image)\"\r\n          :location=\"event.location\"\r\n          :title=\"event.name\"\r\n          :description=\"event.brief\"\r\n        />\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Slider for mobile -->\r\n    <swiper\r\n      v-show=\"isMobile\"\r\n      :slides-per-view=\"slidesPerView\"\r\n      :space-between=\"16\"\r\n      class=\"swiper-layout\"\r\n    >\r\n      <swiper-slide v-for=\"event in events\" :key=\"event.id\">\r\n        <router-link\r\n          :to=\"{\r\n            name: 'EventView',\r\n            params: { id: event.id },\r\n            query: { eventData: JSON.stringify(event) },\r\n          }\"\r\n          class=\"card-link\"\r\n        >\r\n          <EventCard\r\n            class=\"event-card\"\r\n            :imgUrl=\"getImageUrl(event.image)\"\r\n            :location=\"event.location\"\r\n            :title=\"event.name\"\r\n            :description=\"event.brief\"\r\n          />\r\n        </router-link>\r\n      </swiper-slide>\r\n    </swiper>\r\n  </section>\r\n</template>\r\n\r\n<script>\r\nimport { Swiper, SwiperSlide } from \"swiper/vue\";\r\nimport \"swiper/swiper-bundle.css\";\r\nimport eventData from \"@/assets/data/events.json\";\r\nimport EventCard from \"../EventCard.vue\";\r\n\r\nexport default {\r\n  components: { Swiper, SwiperSlide, EventCard },\r\n  data() {\r\n    return {\r\n      events: eventData.events,\r\n      screenWidth: window.innerWidth, // Track screen width\r\n      isMobile: window.innerWidth < 800, // Determine if the screen is mobile (less than 800px)\r\n    };\r\n  },\r\n  computed: {\r\n    // Dynamically compute slidesPerView based on screen width\r\n    slidesPerView() {\r\n      if (this.screenWidth < 500) {\r\n        return 1; // 1 card for screens less than 500px\r\n      } else if (this.screenWidth < 800) {\r\n        return 2; // 2 cards for screens between 500px and 800px\r\n      } else {\r\n        return 3; // 3 cards for screens larger than 800px\r\n      }\r\n    },\r\n  },\r\n  methods: {\r\n    getImageUrl(imagePath) {\r\n      return require(\"@/assets/images/\" + imagePath);\r\n    },\r\n    // Update screenWidth and isMobile when the window is resized\r\n    updateScreenWidth() {\r\n      this.screenWidth = window.innerWidth;\r\n      this.isMobile = this.screenWidth < 800;\r\n    },\r\n  },\r\n  mounted() {\r\n    // Add resize event listener when component is mounted\r\n    window.addEventListener(\"resize\", this.updateScreenWidth);\r\n  },\r\n  beforeDestroy() {\r\n    // Clean up the event listener when the component is destroyed\r\n    window.removeEventListener(\"resize\", this.updateScreenWidth);\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped lang=\"scss\">\r\n.events {\r\n  width: 100%;\r\n  height: fit-content;\r\n  background-color: $black;\r\n  color: white;\r\n\r\n  h1 {\r\n    padding-bottom: 24px;\r\n    text-align: center;\r\n  }\r\n\r\n  /* Flexbox Layout for large screens */\r\n  .flexbox-layout {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 16px; /* This creates space between the cards */\r\n    justify-content: center;\r\n\r\n    .event-card {\r\n      flex: 1 0 30%; /* Adjust card size as needed */\r\n      max-width: 400px;\r\n      min-height: 250px; /* Minimum height for uniform cards */\r\n    }\r\n  }\r\n\r\n  /* Swiper Layout for smaller screens */\r\n  .swiper-layout {\r\n    width: 100%;\r\n    height: 60vh; /* Adjust height as needed */\r\n    background-color: aliceblue;\r\n\r\n    .swiper-slide {\r\n      display: flex;\r\n      justify-content: center;\r\n      align-items: center;\r\n      height: 100%;\r\n    }\r\n\r\n    .card-link {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      flex: 1;\r\n      max-width: 100%;\r\n      margin: 0 8px;\r\n\r\n      .event-card {\r\n        flex: 1;\r\n        height: 100%;\r\n      }\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAuDA,SAASA,MAAM,EAAEC,WAAU,QAAS,YAAY;AAChD,OAAO,0BAA0B;AACjC,OAAOC,SAAQ,MAAO,2BAA2B;AACjD,OAAOC,SAAQ,MAAO,kBAAkB;AAExC,eAAe;EACbC,UAAU,EAAE;IAAEJ,MAAM;IAAEC,WAAW;IAAEE;EAAU,CAAC;EAC9CE,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAEJ,SAAS,CAACI,MAAM;MACxBC,WAAW,EAAEC,MAAM,CAACC,UAAU;MAAE;MAChCC,QAAQ,EAAEF,MAAM,CAACC,UAAS,GAAI,GAAG,CAAE;IACrC,CAAC;EACH,CAAC;EACDE,QAAQ,EAAE;IACR;IACAC,aAAaA,CAAA,EAAG;MACd,IAAI,IAAI,CAACL,WAAU,GAAI,GAAG,EAAE;QAC1B,OAAO,CAAC,EAAE;MACZ,OAAO,IAAI,IAAI,CAACA,WAAU,GAAI,GAAG,EAAE;QACjC,OAAO,CAAC,EAAE;MACZ,OAAO;QACL,OAAO,CAAC,EAAE;MACZ;IACF;EACF,CAAC;EACDM,OAAO,EAAE;IACPC,WAAWA,CAACC,SAAS,EAAE;MACrB,OAAOC,OAAO,CAAC,kBAAiB,GAAID,SAAS,CAAC;IAChD,CAAC;IACD;IACAE,iBAAiBA,CAAA,EAAG;MAClB,IAAI,CAACV,WAAU,GAAIC,MAAM,CAACC,UAAU;MACpC,IAAI,CAACC,QAAO,GAAI,IAAI,CAACH,WAAU,GAAI,GAAG;IACxC;EACF,CAAC;EACDW,OAAOA,CAAA,EAAG;IACR;IACAV,MAAM,CAACW,gBAAgB,CAAC,QAAQ,EAAE,IAAI,CAACF,iBAAiB,CAAC;EAC3D,CAAC;EACDG,aAAaA,CAAA,EAAG;IACd;IACAZ,MAAM,CAACa,mBAAmB,CAAC,QAAQ,EAAE,IAAI,CAACJ,iBAAiB,CAAC;EAC9D;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}